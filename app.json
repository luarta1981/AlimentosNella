{
  "expo": {
    "name": "AlimentosNella",
    "slug": "AlimentosNella",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alimentosnella",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.alimentosnella.AlimentosNella"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/LOGO SIN FONDO.png",
          "color": "#8B0000",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF3E2",
          "image": "./assets/images/LOGO SIN FONDO.png",
          "imageWidth": 280,
          "android": {
            "image": "./assets/images/LOGO SIN FONDO.png",
            "imageWidth": 280
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5d5bb90b-e805-4604-bd2f-380e95c24f4e"
      }
    }
  }
}
